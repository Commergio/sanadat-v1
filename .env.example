# ─── MVP prototype (management demo) ─────────────────────────────────────────
# Leave Supabase empty → app runs in demo mode automatically (mock data, open routes).
# For production later: set Supabase keys and NEXT_PUBLIC_DEMO_MODE=false

NEXT_PUBLIC_DEMO_MODE=true
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional — only needed for real auth/database (phase 2)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional — payment gateways (phase 2; demo redirects without keys)
MOYASAR_API_KEY=
MOYASAR_PUBLISHABLE_KEY=
HYPERPAY_ENTITY_ID=
HYPERPAY_ACCESS_TOKEN=
STC_PAY_MERCHANT_ID=
