# Sanadat production — Supabase required for dashboard/auth

# Local dev: http://localhost:3000
# Vercel production: https://sanadat-v1-go457cy2u-commergios-projects.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Required for P2.2+ billing checkout writes (server-only; never expose to client)
SUPABASE_SERVICE_ROLE_KEY=

# P2.3 manual webhook testing: POST /api/billing/webhook/manual
BILLING_MANUAL_WEBHOOK_SECRET=

# P2.5 Moyasar checkout — set PAYMENTS_MODE and matching API keys
# sandbox (default): sk_test_ / pk_test_
# live: requires PAYMENTS_MODE=live and sk_live_ / pk_live_
PAYMENTS_MODE=sandbox
MOYASAR_SECRET_KEY=
MOYASAR_PUBLIC_KEY=
# P2.5.2 Moyasar webhooks — same secret as configured in Moyasar Dashboard webhook endpoint
MOYASAR_WEBHOOK_SECRET=
HYPERPAY_ENTITY_ID=
HYPERPAY_ACCESS_TOKEN=
STC_PAY_MERCHANT_ID=
