  "faq": {
    "label": "FAQ",
    "title": "Frequently asked questions",
    "items": {
      "edit": { "q": "Can I edit a document after creation?", "a": "No. Documents are immutable after creation for reliability. You can only cancel with a reason; cancelled docs remain visible." },
      "cancel": { "q": "What happens when I cancel a document?", "a": "It is marked as cancelled and stays in the log with its original number. Numbers are never reused." },
      "tax": { "q": "Does it support tax invoices?", "a": "Designed for non-tax invoices and receipt/payment vouchers. ZATCA tax invoice support is planned for the future." },
      "subscription": { "q": "How does subscription & renewal work?", "a": "SAR 399/year with optional auto-renewal. Notifications 7, 3, and 1 days before expiry." },
      "payments": { "q": "Which payment gateways are supported?", "a": "Ready for Moyasar, HyperPay, and STC Pay, with Mada, Visa, and Apple Pay." }
    }
  },
